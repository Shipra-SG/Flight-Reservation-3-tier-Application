pipeline {
    agent any
    stages {
        stage ('Code-Pull') {
            steps {
                git branch: 'main', url: 'https://github.com/mayurmwagh/flight-reservation-app.git'
            }
        }

    stage ('Build') {
            steps {
                sh '''
                 cd FlightReservationApplication
                 mvn clean package -DskipTests
                '''
            }
        }

    stage ('Code-Quality-Test') {
            steps {
                withSonarQubeEnv(installationName: 'sonar' , credentialsId: 'sonar') {
                sh '''
                 cd FlightReservationApplication
                 mvn clean verify sonar:sonar \
                 -DskipTests \
                 -Dsonar.projectKey=flight-app \
                 -Dsonar.projectName='flight-app' \
                '''
                }
            }
        }

    stage ('Docker Build') {
            steps {
                sh '''
                 cd FlightReservationApplication
                 docker build -t shiprag321/flight-reservation-backend:latest .
                 docker push shiprag321/flight-reservation-backend:latest
                 docker rmi shiprag321/flight-reservation-backend:latest
                '''
                }
            }
    stage ('Deploy') {
            steps {
                sh '''
                 cd flight-reservation-app/FlightReservationApplication/k8s
                 kubectl apply -f .
                '''
                }
            }
    }
}
